# =============================================================================
# WC3 Coach — Local environment template
# =============================================================================
# Copy this file to .env before running docker compose:
#   cp .env.example .env          (Linux/macOS/Git Bash)
#   copy .env.example .env        (Windows CMD)
#   Copy-Item .env.example .env   (PowerShell)
#
# .env is git-ignored and never committed. .env.example IS committed and
# serves as the canonical list of required variables.
#
# These are LOCAL-ONLY credentials for a personal dev machine — there is no
# public-facing service, so simple passwords are acceptable here.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL (used by docker-compose.yml to create the superuser + database
# on first start, and by api-node / api-py to connect)
# ---------------------------------------------------------------------------
POSTGRES_USER=wc3coach
POSTGRES_PASSWORD=wc3coach
POSTGRES_DB=wc3coach

# ---------------------------------------------------------------------------
# Connection strings (used by host-side apps: api-node, api-py, migrations)
# These reference localhost because the apps run on the host during dev and
# reach the container through the mapped port 5432.
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://wc3coach:wc3coach@localhost:5432/wc3coach

# ---------------------------------------------------------------------------
# Redis
# BullMQ job queues for the parse pipeline.
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Ollama
# The Python API (FastAPI) and Node API call this endpoint for LLM inference
# and embeddings. Ollama runs in Docker (with GPU) and is reachable on the
# host at port 11434.
# ---------------------------------------------------------------------------
OLLAMA_HOST=http://localhost:11434

# ---------------------------------------------------------------------------
# Node API (apps/api-node)
# ---------------------------------------------------------------------------

# HTTP port for the Fastify ingest API.
# Default: 8787
PORT=8787

# Directory where uploaded .w3g replay files are stored on the host.
# Relative paths are resolved from the repo root.
# This directory is git-ignored (game-data/).
# Default: <repo-root>/game-data/uploads
# REPLAY_STORAGE_DIR=./game-data/uploads

# Number of parallel replay-parse workers (BullMQ worker concurrency).
# The Ryzen 7 9700X has 16 threads; 4 leaves headroom for DB and UI.
# Default: 4
# INGEST_CONCURRENCY=4

# ---------------------------------------------------------------------------
# Optional overrides (uncomment as needed)
# ---------------------------------------------------------------------------
# OLLAMA_KEEP_ALIVE=24h       # how long to keep a model loaded in VRAM
# OLLAMA_NUM_GPU=1            # force a specific GPU count inside the container
