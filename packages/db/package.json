{
  "name": "@wc3-coach/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "lint": "echo \"lint: no linter configured yet\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist *.tsbuildinfo",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --loader tsx/esm src/migrate.ts"
  },
  "dependencies": {
    "@wc3-coach/shared-types": "workspace:*",
    "drizzle-orm": "^0.44.2",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.11",
    "drizzle-kit": "^0.31.1",
    "tsx": "^4.22.4",
    "typescript": "*",
    "vitest": "^4.1.8"
  }
}
